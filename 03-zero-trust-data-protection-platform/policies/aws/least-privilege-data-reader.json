{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadSpecificProtectedBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::enterprise-sensitive-data-bucket",
        "arn:aws:s3:::enterprise-sensitive-data-bucket/*"
      ]
    },
    {
      "Sid": "DecryptWithSpecificKey",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "arn:aws:kms:us-east-1:123456789012:key/example-key-id"
    }
  ]
}
